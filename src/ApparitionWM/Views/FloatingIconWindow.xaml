<Window x:Class="ApparitionWM.Views.FloatingIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apparition"
        Width="60" Height="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="IconGrid"
                             Storyboard.TargetProperty="Opacity"
                             To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetName="IconGrid"
                             Storyboard.TargetProperty="Opacity"
                             To="0.4" Duration="0:0:0.5" />
        </Storyboard>
        <Storyboard x:Key="PulseGlow">
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.6" Duration="0:0:0.3"
                             AutoReverse="True"
                             RepeatBehavior="1x" />
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="IconGrid" Opacity="0.5"
          MouseDown="Icon_MouseDown"
          MouseEnter="Icon_MouseEnter"
          MouseLeave="Icon_MouseLeave">

        <!-- Glow backdrop -->
        <Ellipse x:Name="GlowEffect"
                 Width="58" Height="58"
                 Opacity="0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#607C3AED" Offset="0" />
                    <GradientStop Color="#007C3AED" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Main icon circle -->
        <Ellipse Width="48" Height="48"
                 StrokeThickness="2">
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF1A1A2E" Offset="0" />
                    <GradientStop Color="#FF252540" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Fill>
            <Ellipse.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF7C3AED" Offset="0" />
                    <GradientStop Color="#FF6D28D9" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Stroke>
        </Ellipse>

        <!-- Ghost icon (simple path) -->
        <Viewbox Width="24" Height="24" Margin="0,0,0,2">
            <Canvas Width="24" Height="24">
                <Path Fill="#FFA78BFA"
                      Data="M12,2 C7.58,2 4,5.58 4,10 L4,20 C4,20.55 4.45,21 5,21 L6,21 C6.55,21 7,20.55 7,20 L7,19 L8,20 C8,20.55 8.45,21 9,21 L10,21 C10.55,21 11,20.55 11,20 L11,19 L13,19 L13,20 C13,20.55 13.45,21 14,21 L15,21 C15.55,21 16,20.55 16,20 L16,19 L17,20 C17,20.55 17.45,21 18,21 L19,21 C19.55,21 20,20.55 20,20 L20,10 C20,5.58 16.42,2 12,2 Z M9.5,12 C8.67,12 8,11.33 8,10.5 C8,9.67 8.67,9 9.5,9 C10.33,9 11,9.67 11,10.5 C11,11.33 10.33,12 9.5,12 Z M14.5,12 C13.67,12 13,11.33 13,10.5 C13,9.67 13.67,9 14.5,9 C15.33,9 16,9.67 16,10.5 C16,11.33 15.33,12 14.5,12 Z" />
            </Canvas>
        </Viewbox>

        <!-- Right-click context menu -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Show Panel" Click="ShowPanel_Click" FontWeight="Bold" />
                <Separator />
                <MenuItem Header="Settings" Click="Settings_Click" />
                <Separator />
                <MenuItem Header="Exit" Click="Exit_Click" />
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
