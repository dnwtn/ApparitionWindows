<Window x:Class="ApparitionWM.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apparition — Settings"
        Width="420" Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Border CornerRadius="12" Margin="8"
            Background="{StaticResource PanelGradient}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4"
                              Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />   <!-- Header -->
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />      <!-- Content -->
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />   <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ── Header ──────────────────────────────────── -->
            <Grid Grid.Row="0" MouseDown="Header_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="⚙  Settings"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <Button Grid.Column="1"
                        Content="✕" FontSize="14"
                        Width="28" Height="28" Padding="0"
                        Command="{Binding CancelCommand}" />
            </Grid>

            <!-- ── Content ─────────────────────────────────── -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- General -->
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}" />

                    <CheckBox Content="Restore all windows on close"
                              IsChecked="{Binding RestoreOnClose}"
                              Margin="0,6" />

                    <CheckBox Content="Show floating desktop icon"
                              IsChecked="{Binding ShowFloatingIcon}"
                              Margin="0,6" />

                    <CheckBox Content="Start with Windows"
                              IsChecked="{Binding AutoStart}"
                              Margin="0,6" />

                    <!-- Transparency -->
                    <TextBlock Text="TRANSPARENCY" Style="{StaticResource SectionHeader}"
                               Margin="0,16,0,4" />

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Quick transparency"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Grid.Column="1"
                                Value="{Binding QuickTransparency}"
                                Minimum="10" Maximum="100"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentLightBrush}">
                            <TextBlock.Text>
                                <Binding Path="QuickTransparency" StringFormat="{}{0}%" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Icon idle opacity"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                        <Slider Grid.Column="1"
                                Value="{Binding IconTransparency}"
                                Minimum="10" Maximum="100"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentLightBrush}">
                            <TextBlock.Text>
                                <Binding Path="IconTransparency" StringFormat="{}{0}%" />
                            </TextBlock.Text>
                        </TextBlock>
                    </Grid>

                    <!-- Hotkeys -->
                    <TextBlock Text="HOTKEYS" Style="{StaticResource SectionHeader}"
                               Margin="0,16,0,4" />

                    <ItemsControl ItemsSource="{Binding Hotkeys}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Action}"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource BgSurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8,3">
                                        <TextBlock Text="{Binding DisplayString}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource AccentLightBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Presets -->
                    <TextBlock Text="SAVED PRESETS" Style="{StaticResource SectionHeader}"
                               Margin="0,16,0,4" />

                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Margin="8,0"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} · {1}">
                                                <Binding Path="Mode" />
                                                <Binding Path="Opacity" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Presets are saved via the control panel."
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </ScrollViewer>

            <!-- ── Footer Buttons ──────────────────────────── -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Cancel"
                        Command="{Binding CancelCommand}" />
                <Button Grid.Column="2"
                        Content="Save"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding SaveCommand}" />
            </Grid>
        </Grid>
    </Border>
</Window>
